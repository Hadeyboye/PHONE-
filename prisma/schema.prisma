generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  lookups   Lookup[]
}

model Lookup {
  id          String   @id @default(cuid())
  number      String
  carrier     String
  location    String
  ownerInfo   Json?
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}
